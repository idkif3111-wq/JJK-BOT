# apps/bot/../../.env.example

# Discord Bot
DISCORD_TOKEN=your_bot_token_here
DISCORD_GUILD_ID=your_guild_id_here

# Admin Settings
ADMIN_ROLE_IDS=123456789,987654321
MODERATOR_ROLE_IDS=111111111,222222222

# PostgreSQL
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=mmorpg_user
POSTGRES_PASSWORD=secure_password
POSTGRES_DB=jjk_mmorpg

# MongoDB
MONGO_HOST=mongo
MONGO_PORT=27017
MONGO_USER=mmorpg_user
MONGO_PASSWORD=secure_password
MONGO_DB=jjk_mmorpg

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0

# Environment
ENVIRONMENT=production
LOG_LEVEL=INFO

# Dashboard
DASHBOARD_HOST=0.0.0.0
DASHBOARD_PORT=8000
DASHBOARD_SECRET_KEY=your_secret_key_here
